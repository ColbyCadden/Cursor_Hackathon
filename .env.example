# Copy to .env.local for local dev (never commit .env.local)

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq (free tier, no card) — https://console.groq.com/keys
# Used automatically when Gemini hits rate limits (doubles effective capacity)
GROQ_API_KEY=your-groq-key-here

# Optional model overrides (each has built-in fallbacks)
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.1-8b-instant
